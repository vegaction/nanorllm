{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Trajectory Viewer Data",
  "description": "Minimal schema for the standalone trajectory viewer. The HTML viewer reads only this JSON shape.",
  "type": "object",
  "required": [
    "meta",
    "trajectories"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "env_name",
        "created_at",
        "source",
        "num_trajectories"
      ],
      "properties": {
        "env_name": {
          "type": "string",
          "description": "Environment name, for example MathEnv."
        },
        "created_at": {
          "type": "string",
          "description": "Timestamp in ISO-8601 format."
        },
        "source": {
          "type": "string",
          "description": "Origin label such as manual-export or train_math_grpo."
        },
        "num_trajectories": {
          "type": "integer",
          "minimum": 0,
          "description": "Declared trajectory count. The viewer recomputes its own display stats."
        }
      },
      "additionalProperties": true
    },
    "trajectories": {
      "type": "array",
      "description": "Primary data source for the viewer.",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "sample_index",
          "final_reward",
          "terminated",
          "termination_reason",
          "task",
          "steps"
        ],
        "properties": {
          "task_id": {
            "type": "string"
          },
          "sample_index": {
            "type": "integer",
            "minimum": 0
          },
          "final_reward": {
            "type": "number"
          },
          "terminated": {
            "type": "boolean"
          },
          "termination_reason": {
            "type": "string"
          },
          "task": {
            "type": "object",
            "required": [
              "question"
            ],
            "properties": {
              "question": {
                "type": "string"
              },
              "answer": {
                "type": [
                  "string",
                  "number",
                  "null"
                ]
              }
            },
            "additionalProperties": true
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "index"
              ],
              "properties": {
                "index": {
                  "type": "integer",
                  "minimum": 0
                },
                "observation": {
                  "type": [
                    "object",
                    "string",
                    "null"
                  ]
                },
                "prompt_messages": {
                  "type": [
                    "array",
                    "null"
                  ],
                  "items": {
                    "type": "object",
                    "required": [
                      "role",
                      "content"
                    ],
                    "properties": {
                      "role": {
                        "type": "string"
                      },
                      "content": {
                        "type": "string"
                      }
                    },
                    "additionalProperties": true
                  }
                },
                "model_response": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "action": {
                  "type": [
                    "object",
                    "string",
                    "null"
                  ]
                },
                "reward": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "done": {
                  "type": [
                    "boolean",
                    "null"
                  ]
                },
                "info": {
                  "type": [
                    "object",
                    "null"
                  ]
                },
                "training": {
                  "type": [
                    "object",
                    "null"
                  ],
                  "properties": {
                    "advantage": {
                      "type": [
                        "number",
                        "null"
                      ]
                    },
                    "prompt_ids": {
                      "type": [
                        "array",
                        "null"
                      ]
                    },
                    "response_ids": {
                      "type": [
                        "array",
                        "null"
                      ]
                    },
                    "rollout_logprobs": {
                      "type": [
                        "array",
                        "null"
                      ]
                    }
                  },
                  "additionalProperties": true
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
